{
  "name": "padel-backend",
  "private": true,
  "description": "Scripts npm pour lancer Django depuis le dossier backend (Windows).",
  "scripts": {
    "dev": "python manage.py runserver",
    "dev:pipenv": "pipenv run python manage.py runserver",
    "migrate": "python manage.py migrate",
    "migrate:pipenv": "pipenv run python manage.py migrate",
    "seed": "python manage.py seed_admin",
    "seed:pipenv": "pipenv run python manage.py seed_admin"
  }
}
